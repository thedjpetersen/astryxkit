{
  "name": "app-foundry",
  "version": "0.1.0",
  "description": "Design-system-neutral framework for independently developed application modules.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedjpetersen/app-foundry.git"
  },
  "bugs": {
    "url": "https://github.com/thedjpetersen/app-foundry/issues"
  },
  "homepage": "https://github.com/thedjpetersen/app-foundry#readme",
  "keywords": [
    "application-framework",
    "domain-driven-design",
    "micro-app",
    "shell"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "import": "./dist/generator/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "validate": "npm run check && npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260624.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "typescript": "^5.9.2"
  }
}
